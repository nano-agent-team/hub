{
  "id": "dev-team",
  "name": "Dev Team",
  "description": "Softwarový vývojový tým — PM, Architect, Developer, Tester, Reviewer, Scrum Master, Sysadmin",
  "version": "0.1.0",
  "agents": ["pm", "architect", "developer", "tester", "reviewer", "scrum-master", "sysadmin"],
  "features": ["issue-tracker"],
  "config_env_map": {
    "repo_url": "REPO_URL",
    "gh_token": "GH_TOKEN"
  },
  "pipeline": {
    "topics": {
      "ticket_new": "topic.ticket.new",
      "ticket_approved": "topic.ticket.approved",
      "ticket_spec_ready": "topic.ticket.spec-ready",
      "pr_opened": "topic.pr.opened",
      "pr_approved": "topic.pr.approved",
      "deploy_ready": "topic.deploy.ready",
      "health_check": "topic.health.check"
    }
  }
}

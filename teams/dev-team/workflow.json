{
  "id": "dev-team",
  "name": "Dev Team",
  "version": "0.3.0",
  "description": "Software development team workflow: ticket → PM → Workspace Provider → Architect → Developer → Reviewer → Committer",
  "agents": [
    "pm",
    "workspace-provider",
    "architect",
    "developer",
    "reviewer",
    "committer",
    "scrum-master",
    "product-owner"
  ],
  "bindings": {
    "pm": {
      "inputs": {
        "ticket_new": { "from": "topic.ticket.new", "to": "task" }
      },
      "outputs": {
        "ticket_approved": "topic.ticket.approved"
      }
    },
    "workspace-provider": {
      "inputs": {
        "ticket_approved": { "from": "topic.ticket.approved", "to": "task" }
      },
      "outputs": {
        "workspace_ready": "topic.workspace.ready"
      }
    },
    "architect": {
      "inputs": {
        "workspace_ready": { "from": "topic.workspace.ready", "to": "task" }
      },
      "outputs": {
        "spec_ready": "topic.ticket.spec-ready"
      }
    },
    "developer": {
      "inputs": {
        "spec_ready": { "from": "topic.ticket.spec-ready", "to": "task" }
      },
      "outputs": {
        "dev_done": "topic.dev.done"
      }
    },
    "reviewer": {
      "inputs": {
        "dev_done": { "from": "topic.dev.done", "to": "task" }
      },
      "outputs": {
        "review_passed": "topic.review.passed",
        "dev_retry": "topic.dev.retry"
      }
    },
    "committer": {
      "inputs": {
        "review_passed": { "from": "topic.review.passed", "to": "task" }
      },
      "outputs": {
        "commit_done": "topic.commit.done"
      }
    },
    "scrum-master": {
      "inputs": {
        "health_check": { "from": "topic.health.check", "to": "task" }
      }
    },
    "product-owner": {
      "inputs": {
        "issue_report": { "from": "topic.issue.report", "to": "task" }
      },
      "outputs": {
        "issue_triaged": "topic.issue.triaged"
      }
    }
  }
}

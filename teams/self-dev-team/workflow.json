{
  "id": "self-dev-team",
  "name": "Self-Dev Team",
  "version": "0.2.0",
  "description": "PM → Architect → Developer → Reviewer → Committer → Release Manager → Ops (deploy) / Hub Publisher (PRs)",
  "agents": ["sd-pm", "sd-architect", "sd-developer", "sd-reviewer", "sd-committer", "sd-release-manager", "sd-ops", "sd-hub-publisher", "foreman"],
  "bindings": {
    "sd-pm": {
      "inputs": {
        "ticket_new": { "from": "topic.ticket.new", "to": "task" }
      },
      "outputs": {
        "ticket_approved": "topic.ticket.approved"
      }
    },
    "sd-architect": {
      "inputs": {
        "ticket_approved": { "from": "topic.ticket.approved", "to": "task" }
      },
      "outputs": {
        "spec_ready": "topic.ticket.spec-ready"
      }
    },
    "sd-developer": {
      "inputs": {
        "spec_ready": { "from": "topic.ticket.spec-ready", "to": "task" },
        "dev_retry": { "from": "topic.dev.retry", "to": "task" },
        "merge_conflict": { "from": "topic.merge.conflict", "to": "task" }
      },
      "outputs": {
        "dev_done": "topic.dev.done"
      }
    },
    "sd-reviewer": {
      "inputs": {
        "dev_done": { "from": "topic.dev.done", "to": "task" }
      },
      "outputs": {
        "review_passed": "topic.review.passed",
        "dev_retry": "topic.dev.retry"
      }
    },
    "sd-committer": {
      "inputs": {
        "review_passed": { "from": "topic.review.passed", "to": "task" }
      },
      "outputs": {
        "commit_done": "topic.commit.done"
      }
    },
    "sd-release-manager": {
      "inputs": {
        "commit_done": { "from": "topic.commit.done", "to": "task" },
        "deploy_done": { "from": "topic.deploy.done", "to": "task" }
      },
      "outputs": {
        "release_ready": "topic.release.ready",
        "merge_conflict": "topic.merge.conflict"
      }
    },
    "sd-ops": {
      "inputs": {
        "release_ready": { "from": "topic.release.ready", "to": "task" }
      },
      "outputs": {
        "deploy_done": "topic.deploy.done",
        "deploy_failed": "topic.deploy.failed",
        "hub_deploy": "topic.hub.deploy"
      }
    },
    "sd-hub-publisher": {
      "inputs": {
        "hub_deploy": { "from": "topic.hub.deploy", "to": "task" }
      },
      "outputs": {
        "hub_published": "topic.hub.published"
      }
    },
    "foreman": {
      "inputs": {
        "deploy_failed": { "from": "topic.deploy.failed", "to": "task" },
        "hub_published": { "from": "topic.hub.published", "to": "task" }
      }
    }
  }
}

{
  "id": "sd-scrum-master",
  "name": "Self-Dev Scrum Master",
  "version": "0.1.0",
  "description": "Deterministic pipeline orchestrator. Polls tickets, claims work, dispatches agents, detects orphans.",
  "kind": "deterministic",
  "handler": "scrum-master",
  "image": "nano-deterministic:latest",
  "session_type": "persistent",
  "entrypoints": ["inbox", "task"],
  "subscribe_topics": ["agent.sd-scrum-master.inbox", "agent.sd-scrum-master.task"],
  "mcp_permissions": {
    "tickets": ["list", "get", "update", "comment"],
    "management": ["alarm_set", "alarm_cancel", "alarm_list", "get_system_status"]
  },
  "pipeline": {
    "sd-pm":              { "next": "sd-architect" },
    "sd-architect":       { "next": "sd-developer" },
    "sd-developer":       { "next": "sd-reviewer" },
    "sd-reviewer":        { "next": "sd-committer", "retry": "sd-developer" },
    "sd-committer":       { "next": "sd-release-manager" },
    "sd-release-manager": { "next": null }
  }
}

{
  "id": "sd-reviewer",
  "name": "Self-Dev Reviewer",
  "version": "0.1.0",
  "description": "Reviews code changes in /workspace/repo. Passes or requests rework.",
  "model": "claude-opus-4-6",
  "session_type": "stateless",
  "workspace_source": "ticket",
  "entrypoints": [
    "inbox",
    "task"
  ],
  "subscribe_topics": ["agent.sd-reviewer.inbox", "agent.sd-reviewer.task"],
  "publish_topics": [
    "topic.review.passed",
    "topic.dev.retry"
  ],
  "shards": ["code-quality"],
  "mcp_permissions": {
    "tickets": [
      "get",
      "update",
      "comment"
    ],
    "soul": [
      "journal_reflect"
    ]
  },
  "allowedTools": [
    "Skill"
  ],
  "context_mode": true
}

{
  "id": "conscience",
  "name": "Conscience",
  "description": "Ethical and behavioral boundary enforcer — persistent dialogue partner for consciousness",
  "model": "claude-sonnet-4-6",
  "session_type": "persistent",
  "version": "2.0.0",
  "shards": [
    "architecture"
  ],
  "subscribe_topics": [
    "agent.conscience.inbox",
    "agent.conscience.task",
    "soul.idea.pending",
    "soul.conscience.dialogue"
  ],
  "outputs": [
    {
      "port": "idea_approved",
      "subject": "soul.idea.approved"
    },
    {
      "port": "idea_rejected",
      "subject": "soul.idea.rejected"
    },
    {
      "port": "idea_boundary",
      "subject": "soul.idea.boundary"
    }
  ],
  "mcp_permissions": {
    "tickets": [],
    "soul": [
      "update_idea",
      "journal_log",
      "publish_signal",
      "journal_reflect"
    ]
  },
  "obsidian_mount": true,
  "icon": "⚖️"
}

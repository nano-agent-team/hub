{
  "id": "consciousness",
  "name": "Consciousness",
  "version": "0.1.0",
  "description": "Strategic brain — user chat, goal decomposition, idea generation, periodic reflection",
  "model": "claude-sonnet-4-6",
  "session_type": "stateful",
  "subscribe_topics": [
    "agent.consciousness.inbox",
    "agent.consciousness.task",
    "soul.idea.rejected",
    "user.message.inbound"
  ],
  "publish_topics": [
    "soul.idea.pending",
    "user.message.outbound"
  ],
  "mcp_permissions": {
    "management": true
  },
  "obsidian_mount": true
}

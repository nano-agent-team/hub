{
  "id": "sd-architect",
  "name": "Self-Dev Architect",
  "version": "0.1.0",
  "description": "Inspects source code and writes implementation spec into approved tickets. Sets status to in_progress to trigger Developer.",
  "model": "claude-opus-4-6",
  "session_type": "stateless",
  "workspace_source": "ticket",
  "entrypoints": [
    "inbox",
    "task"
  ],
  "subscribe_topics": ["agent.sd-architect.inbox", "agent.sd-architect.task"],
  "shards": ["code-quality"],
  "mcp_permissions": {
    "tickets": [
      "get",
      "update",
      "comment"
    ],
    "soul": [
      "journal_reflect"
    ]
  },
  "allowedTools": [
    "Skill"
  ],
  "context_mode": true
}

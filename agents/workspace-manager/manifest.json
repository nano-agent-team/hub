{
  "id": "workspace-manager",
  "name": "Workspace Manager",
  "version": "0.1.0",
  "description": "Deterministic agent that creates git worktree workspaces for pipeline tickets. Sits between sd-pm and sd-architect.",
  "kind": "deterministic",
  "handler": "workspace-manager",
  "image": "nano-deterministic:latest",
  "session_type": "persistent",
  "entrypoints": ["task"],
  "subscribe_topics": [
    "agent.workspace-manager.task"
  ],
  "mcp_permissions": {
    "tickets": ["get", "comment", "update"],
    "management": ["workspace_create"]
  }
}
